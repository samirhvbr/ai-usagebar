/target
**/*.rs.bk

# Sandbox marker, not part of the project.
.ai-jail

# Local secrets — never commit
.env
.env.local
*.credentials.json

# Snapshot review files from `cargo insta`
*.snap.new

# makepkg build outputs (kept out of the source repo)
packaging/aur/pkg/
packaging/aur/src/
packaging/aur/*.pkg.tar.*
packaging/aur/*.tar.gz

# Claude Code - config local da sessao
.claude/settings.local.json

# GNOME extension — compiled schema (build artifact)
gnome-extension/schemas/gschemas.compiled

# macOS menubar — compiled Swift binary (build artifact of macos/build.sh)
macos/ai-usagebar-menubar

# Clones temporários (ex: fork do EaeDave) — nunca commitar
/tmp/
